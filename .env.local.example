# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the client/browser.
# Used for privileged admin actions (Phase 2: staff/salesman account creation, etc).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL, used for auth email redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
